# ============================================
# MediLink Environment Configuration
# ============================================

# API Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

# Database
DB_CONNECTION_STRING=Server=(localdb)\mssqllocaldb;Database=MediLink_Dev;Trusted_Connection=true;

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-min-32-chars-do-not-use-in-production-change-this-value
JWT_ISSUER=MediLink
JWT_AUDIENCE=MediLink
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Configuration
EMAIL_PROVIDER=SendGrid
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM_ADDRESS=noreply@medilink.com
EMAIL_FROM_NAME=MediLink

# Application Settings
APPOINTMENT_ADVANCE_PAYMENT=50
CONSULTATION_PRICE=150
TIME_SLOT_DURATION_MINUTES=30
TIME_SLOT_START_HOUR=9
TIME_SLOT_END_HOUR=17
MAX_DAYS_AHEAD=60
ARCHIVE_RETENTION_DAYS=2555

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:5000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Logging
LOG_LEVEL=Debug
LOG_FILE_PATH=/var/log/medilink/
